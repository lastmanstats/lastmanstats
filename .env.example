# Last Man Stats — Variabili d'ambiente
# Copia questo file come .env e riempilo con le tue chiavi.
# NON committare mai il file .env su git (già in .gitignore).

# ── DATI PARTITE ─────────────────────────────────────────────────
# football-data.org → My Account > API Token
FOOTBALL_DATA_API_KEY=""

# ── AI TESTO ─────────────────────────────────────────────────────
# Google AI Studio → Get API key > Create API key
GEMINI_API_KEY=""

# ── YOUTUBE ──────────────────────────────────────────────────────
# Google Cloud Console → OAuth 2.0 Client ID (tipo: Desktop app)
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
# Ottenuto una-tantum con lo script get_youtube_token.py
YOUTUBE_REFRESH_TOKEN=""
